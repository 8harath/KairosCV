# Google Gemini API Configuration
# Get your API key from: https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here
# Backward-compatible alias (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=2048

# Application Settings
NODE_ENV=development
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
ENABLE_DEBUG_JSON=false
NEXT_PUBLIC_ENABLE_DEBUG_TOOLS=false

# Local development flags
# In development, auth is bypassed by default unless DISABLE_AUTH=false is set.
DISABLE_AUTH=true
NEXT_PUBLIC_DISABLE_AUTH=true
ENABLE_TRIAL_LIMIT=false

# Advanced extraction layers (optional; increase API calls and processing time)
ENABLE_VISUAL_EXTRACTION=false
ENABLE_FIELD_VERIFICATION=false
ENABLE_OCR_CROSS_VERIFY=false

# Puppeteer Configuration
# Leave PUPPETEER_EXECUTABLE_PATH empty for auto-detection
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=true
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
