# AI Provider Configuration
# Groq is the primary provider (much faster inference). Get your key at: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Google Gemini API (fallback if Groq key is not set)
# Get your API key from: https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# Application Settings
NODE_ENV=development
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
ENABLE_DEBUG_JSON=false
NEXT_PUBLIC_ENABLE_DEBUG_TOOLS=false

# Local development flags
# In development, auth is bypassed by default unless DISABLE_AUTH=false is set.
DISABLE_AUTH=true
NEXT_PUBLIC_DISABLE_AUTH=true
ENABLE_TRIAL_LIMIT=false
TRIAL_LIMIT=3
TRIAL_WINDOW_HOURS=24
# Set both to true for Vercel deployment (required — Vercel has no persistent filesystem)
USE_SUPABASE_STORAGE=false
USE_SUPABASE_TRIALS=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_INPUT_BUCKET=resume-inputs
SUPABASE_OUTPUT_BUCKET=resume-outputs
SUPABASE_JSON_BUCKET=resume-json

# LangSmith Tracing (optional — enables full agent pipeline observability)
# Get your key at: https://smith.langchain.com/
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=kairoscv
LANGCHAIN_TRACING_V2=false

# Advanced extraction layers (optional; increase API calls and processing time)
ENABLE_VISUAL_EXTRACTION=false
ENABLE_FIELD_VERIFICATION=false
ENABLE_OCR_CROSS_VERIFY=false

# Puppeteer Configuration
# Leave PUPPETEER_EXECUTABLE_PATH empty for auto-detection
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_HEADLESS=true
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

# Vercel serverless Chromium configuration
# For Vercel, point this to a hosted Sparticuz chromium pack tarball.
# The branch defaults to the v143 x64 release URL if this is left empty.
CHROMIUM_BINARY_URL=
